{
  "kind": "collectionType",
  "collectionName": "vouchers",
  "info": {
    "singularName": "voucher",
    "pluralName": "vouchers",
    "displayName": "voucher"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "voucherName": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "restaurant",
        "retail",
        "beauty",
        "health",
        "education",
        "entertainment",
        "other"
      ]
    },
    "expiredDate": {
      "type": "date"
    },
    "fullPrice": {
      "type": "integer"
    },
    "packageType": {
      "type": "enumeration",
      "enum": [
        "package299",
        "package599",
        "package899"
      ]
    },
    "voucherAmount": {
      "type": "enumeration",
      "enum": [
        "amount200",
        "amount500",
        "amount1000"
      ]
    },
    "voucherDetail": {
      "type": "text"
    },
    "commissionType": {
      "type": "enumeration",
      "enum": [
        "percent",
        "fixedRate"
      ]
    },
    "commissionAmount": {
      "type": "integer"
    },
    "discount": {
      "type": "integer"
    },
    "voucherStart": {
      "type": "string"
    },
    "voucherEnd": {
      "type": "string"
    },
    "store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store",
      "inversedBy": "vouchers"
    },
    "collections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::collection.collection",
      "mappedBy": "voucher"
    },
    "voucherCover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
